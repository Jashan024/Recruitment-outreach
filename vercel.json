{
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "frame-ancestors 'self' https://gleel2.com https://*.gleel2.com http://localhost:* http://127.0.0.1:*"
                }
            ]
        }
    ]
}
